# Copy this file to .env and fill in your values before running docker compose up

AUDION_ADMIN_USER=admin
AUDION_ADMIN_PASSWORD=           # REQUIRED: Set a strong password
AUDION_JWT_SECRET=               # REQUIRED: Run: openssl rand -hex 32
AUDION_DATA_DIR=/data
AUDION_PORT=8080
AUDION_PUBLIC_DIR=/app/frontend/dist
AUDION_JWT_EXPIRATION_DAYS=7
AUDION_CORS_ORIGIN=*
AUDION_MAX_BODY_SIZE=262144000
RUST_LOG=info
PUID=10001
PGID=10001
